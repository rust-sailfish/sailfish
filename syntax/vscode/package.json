{
  "name": "vscode-rust-sailfish",
  "displayName": "vscode-rust-sailfish",
  "description": "Syntax highlighting for sailfish templates in VSCode",
  "version": "0.1.3",
  "author": "Ryohei Machida <orcinus4627@gmail.com>",
  "publisher": "rust-sailfish",
  "repository": "rust-sailfish/sailfish",
  "license": "MIT",
  "engines": {
    "vscode": ">=1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sailfish",
        "aliases": [
          "sailfish"
        ],
        "extensions": [
          ".stpl",
          ".html.stpl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sailfish",
        "scopeName": "source.sailfish",
        "path": "./syntaxes/sailfish.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "npx tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "npx tsc -p . --outDir out",
    "watch-tests": "npx tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "npx tsc --noEmit",
    "lint": "eslint src/**.ts",
    "test": "vscode-test"
  },
  "dependencies": {
    "lru-cache": ">=11.5.1",
    "prettier": ">=3.8.4",
    "mocha": ">=11.7.6",
    "serialize-javascript": ">=7.0.6"
  },
  "devDependencies": {
    "@eslint/js": ">=10.0.1",
    "@types/mocha": ">=10.0.10",
    "@types/node": ">=26.0.0",
    "@types/vscode": ">=1.125.0",
    "@typescript-eslint/eslint-plugin": ">=8.62.0",
    "@typescript-eslint/parser": ">=8.62.0",
    "@vscode/test-cli": ">=0.0.15",
    "@vscode/test-electron": ">=3.0.0",
    "c8": ">=11.0.0",
    "diff": ">=9.0.0",
    "esbuild": ">=0.28.1",
    "eslint": ">=10.5.0",
    "glob": ">=13.0.6",
    "globals": ">=17.7.0",
    "mocha": ">=11.7.6",
    "npm-run-all": ">=4.1.5",
    "serialize-javascript": ">=7.0.6",
    "test-exclude": ">=8.0.0",
    "typescript": ">=6.0.3",
    "typescript-eslint": ">=8.62.0"
  }
}
